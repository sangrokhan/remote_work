# SPAR 환경 변수 템플릿
# 사용법:
#   1. 본 파일을 `.env`로 복사
#   2. 실제 값으로 채움 (`.env`는 git 추적 제외)
#   3. 시크릿/토큰은 절대 커밋 금지

# ============================================================
# 일반
# ============================================================
SPAR_ENV=development              # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# ============================================================
# LLM 서빙 (vLLM OpenAI-compatible endpoint, 역할별 분리)
# ============================================================
LLM_MAIN_URL=http://localhost:8000/v1
LLM_MAIN_MODEL=qwen2.5-72b-instruct
LLM_MAIN_API_KEY=dummy

LLM_ROUTER_URL=http://localhost:8001/v1
LLM_ROUTER_MODEL=qwen2.5-7b-instruct
LLM_ROUTER_API_KEY=dummy

# Gemini CLI headless fallback (마지막 수단, 옵트인).
# 운영 온프레미스 환경에서는 반드시 false 유지 (외부 API 호출).
# 활성화 전 `gemini auth login` 또는 `GEMINI_API_KEY` 설정 필요.
GEMINI_CLI_FALLBACK_ENABLED=false
GEMINI_CLI_BINARY=gemini
GEMINI_CLI_TIMEOUT_SECONDS=300

# ============================================================
# 벡터 DB (Milvus)
# ============================================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION_PREFIX=spar_

# ============================================================
# BM25 / Elasticsearch (또는 OpenSearch)
# ============================================================
ES_HOST=localhost
ES_PORT=9200
ES_USER=
ES_PASSWORD=
ES_INDEX_PREFIX=spar_

# ============================================================
# Knowledge Graph (Neo4j) — Phase 3
# ============================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ============================================================
# 구조화 DB (PostgreSQL) — Phase 3
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=spar
POSTGRES_USER=spar
POSTGRES_PASSWORD=

# ============================================================
# 데이터셋 다운로드 (HuggingFace Hub)
# ============================================================
# TSpec-LLM(gated) 등 접근에 필요.
# 발급: https://hf.co/settings/tokens (read 권한)
HF_TOKEN=

# ============================================================
# 임베딩 모델 (sentence-transformers)
# ============================================================
EMBED_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_URL=
# OpenAI-compatible embedding endpoint (예: http://<host>:<port>/v1)
# macOS 등에서 별도 sentence-transformers 서버를 띄운 경우 여기에 base URL 설정
# ingest 경로는 EMBEDDING_URL을 사용
EMBEDDING_API_KEY=dummy
ENCODER_URL=
# app/router 경로는 ENCODER_URL 우선, 비어 있으면 EMBEDDING_URL을 사용
ENCODER_MODEL=BAAI/bge-large-en-v1.5
ENCODER_DEVICE=cpu

# ============================================================
# Reranker (cross-encoder)
# ============================================================
RERANKER_URL=http://localhost:8002/rerank
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ============================================================
# 모니터링 (Langfuse) — INF-3
# ============================================================
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
