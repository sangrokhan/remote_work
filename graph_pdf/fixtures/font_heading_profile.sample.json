{
  "heading_rules": [
    {
      "match": {
        "font_size": 20.0
      },
      "assign": {
        "tag": "h1",
        "markdown_prefix": "# "
      }
    },
    {
      "match": {
        "font_size": 16.0
      },
      "assign": {
        "tag": "h2",
        "markdown_prefix": "## "
      }
    },
    {
      "match": {
        "font_size": 13.0
      },
      "assign": {
        "tag": "h3",
        "markdown_prefix": "### "
      }
    }
  ]
}
