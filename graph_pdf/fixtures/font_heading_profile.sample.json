{
  "heading_rules": [
    {
      "match": {
        "font_size": 27.96,
        "max_x0": -1
      },
      "assign": {
        "tag": "h1",
        "markdown_prefix": "# "
      }
    },
    {
      "match": {
        "font_size": 21.96,
        "max_x0": 72.02
      },
      "assign": {
        "tag": "h2",
        "markdown_prefix": "## "
      }
    },
    {
      "match": {
        "font_size": 15.96,
        "max_x0": 72.02
      },
      "assign": {
        "tag": "h3",
        "markdown_prefix": "### "
      }
    },
    {
      "match": {
        "font_size": 12.0,
        "max_x0": 72.02
      },
      "assign": {
        "tag": "h4",
        "markdown_prefix": "#### "
      }
    }
  ]
}
