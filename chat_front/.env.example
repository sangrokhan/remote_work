# npm mirror registry (optional — leave empty to use public npmjs.org)
NPM_REGISTRY=https://your-company-registry.example.com

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_WORKFLOW_WS_URL=ws://10.113.244.133:10001/ws/connect
VITE_WORKFLOW_GRAPH_URL=http://10.113.244.133:10001/graph

# ── LLM credentials ──────────────────────────────────────────────────────────
# GaussO4
GAUSS_O4_API_URL=https://your-gauss-o4-endpoint/v1
GAUSS_O4_API_KEY=your-gauss-o4-api-key

# GaussO4-think
GAUSS_O4_THINK_API_URL=https://your-gauss-o4-think-endpoint/v1
GAUSS_O4_THINK_API_KEY=your-gauss-o4-think-api-key

# Gemma4-E4B-it
GEMMA4_E4B_IT_API_URL=https://your-gemma4-e4b-it-endpoint/v1
GEMMA4_E4B_IT_API_KEY=your-gemma4-e4b-it-api-key

# ── Vector DB (Milvus) ────────────────────────────────────────────────────────
MILVUS_HOST=http://10.113.244.133:19530
MILVUS_DB_NAME=default

# ── Retrieval settings ────────────────────────────────────────────────────────
BM25_SEARCH=false
USE_RERANKER=false
RERANKER_PROVIDER=bge
RERANKER_BGE_URL=http://10.113.244.133:8001/
RERANKER_QWEN3_URL=http://10.113.244.133:8002/
RERANKER_MAX_TOP_N=10
RERANKER_THRESHOLD_RATIO=0.8

# ── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=bgem3
EMBEDDING_URL=http://10.113.244.133:8003/
BGEM3_BASE_URL=http://10.113.244.133:8003/
BGEM3_API_KEY=your-bgem3-api-key

# ── Hybrid search weights (must sum to 1.0) ───────────────────────────────────
WEIGHT_META_SPARSE=0.4
WEIGHT_CONTENTS_DENSE=0.3
WEIGHT_CONTENTS_SPARSE=0.2
WEIGHT_META_DENSE=0.1
