{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/workflow-domain.schema.json",
  "title": "WorkflowDomain",
  "description": "Week 1: 워크플로우 도메인 핵심 타입의 정적 계약",
  "type": "object",
  "required": ["schemaVersion", "workflowId", "version", "nodes", "edges"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "workflowId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{1,63}$",
      "minLength": 2,
      "maxLength": 64,
      "description": "workflow 내/기관 단위에서 고유한 식별자"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/WorkflowNode" },
      "uniqueItems": false
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/definitions/WorkflowEdge" }
    }
  },
  "definitions": {
    "WorkflowNode": {
      "type": "object",
      "required": ["id", "label", "description", "stateKey", "order"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{1,63}$",
          "description": "workflow 내부 nodeId. 노드 고유 식별자"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "stateKey": {
          "type": "string",
          "pattern": "^[a-z][a-zA-Z0-9_-]{0,127}$"
        },
        "metadata": {
          "type": "object",
          "description": "파생 금지: backend가 관리하는 원천 메타데이터만 전달",
          "additionalProperties": true
        },
        "order": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "WorkflowEdge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{1,63}$"
        },
        "from": {
          "type": "string",
          "description": "source nodeId"
        },
        "to": {
          "type": "string",
          "description": "target nodeId"
        },
        "label": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
