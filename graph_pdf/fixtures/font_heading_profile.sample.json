{
  "heading_rules": [
    {
      "match": {
        "font_size": 27.96
      },
      "assign": {
        "tag": "h1",
        "markdown_prefix": "# "
      }
    },
    {
      "match": {
        "font_size": 21.96
      },
      "assign": {
        "tag": "h2",
        "markdown_prefix": "## "
      }
    },
    {
      "match": {
        "font_size": 15.96
      },
      "assign": {
        "tag": "h3",
        "markdown_prefix": "### "
      }
    },
  ]
}
