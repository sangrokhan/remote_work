# SPAR 환경 변수 템플릿
# 사용법:
#   1. 본 파일을 `.env`로 복사
#   2. 실제 값으로 채움 (`.env`는 git 추적 제외)
#   3. 시크릿/토큰은 절대 커밋 금지

# ============================================================
# 일반
# ============================================================
SPAR_ENV=development              # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# ============================================================
# LLM 서빙 (vLLM OpenAI-compatible endpoint)
# ============================================================
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=dummy                 # 사내 vLLM은 더미 키 허용
LLM_MAIN_MODEL=qwen2.5-72b-instruct
LLM_ROUTER_MODEL=qwen2.5-7b-instruct

# ============================================================
# 벡터 DB (Milvus)
# ============================================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION_PREFIX=spar_

# ============================================================
# BM25 / Elasticsearch (또는 OpenSearch)
# ============================================================
ES_HOST=localhost
ES_PORT=9200
ES_USER=
ES_PASSWORD=
ES_INDEX_PREFIX=spar_

# ============================================================
# Knowledge Graph (Neo4j) — Phase 3
# ============================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ============================================================
# 구조화 DB (PostgreSQL) — Phase 3
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=spar
POSTGRES_USER=spar
POSTGRES_PASSWORD=

# ============================================================
# 모니터링 (Langfuse) — INF-3
# ============================================================
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
