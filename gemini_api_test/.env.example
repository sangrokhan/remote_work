# Sample environment for the Gemini traffic experiment.
# Copy to .env and fill in.  (.env is gitignored; docker compose auto-loads it.)
#
#   cp .env.example .env
#
# Quickest start (no GCP, no quota): set GEMINI_MOCK=1 and ignore the rest.

# --- Build mirrors (optional; compose passes these as build args) ----------
# Base image registry mirror (empty = Docker Hub).
BASE_IMAGE=python:3.12-slim
# Internal/regional PyPI mirror (empty = pypi.org).
PIP_INDEX_URL=
PIP_TRUSTED_HOST=

# --- Vertex AI (required for live runs) ------------------------------------
# GCP project + region for Vertex generateContent. Auth is ADC (no API key):
#   local : gcloud auth application-default login
#   Cloud Run : the attached service account (no vars needed beyond these)
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=us-central1

# Local-only: path to a service-account JSON key for ADC.
# Leave empty on Cloud Run (metadata server provides creds).
GOOGLE_APPLICATION_CREDENTIALS=

# --- Mock mode (no GCP / no quota) -----------------------------------------
# 1 = synthetic responses; GOOGLE_CLOUD_PROJECT not needed.
GEMINI_MOCK=0

# --- Firestore history (optional; same ADC) --------------------------------
FIRESTORE_COLLECTION=gemini_runs
FIRESTORE_DATABASE=(default)
# 1 = skip Firestore, write local JSON only.
FIRESTORE_DISABLE=0

# --- Cost estimate ---------------------------------------------------------
GEMINI_PRICE_PER_TOKEN=0.0000001

# --- Packet capture (optional; local/Docker only, needs NET_RAW) -----------
PCAP_DIR=data/pcaps
PCAP_IFACE=any
# 1 = hide/disable the capture toggle.
PCAP_DISABLE=0

# --- Endpoint inspector (optional) -----------------------------------------
TRANSCRIPT_DIR=data/transcripts
# Max response-body bytes captured (1 MiB).
INSPECT_MAX_BODY=1048576

# --- Server ----------------------------------------------------------------
# Cloud Run sets PORT automatically; override locally if needed.
PORT=8080
